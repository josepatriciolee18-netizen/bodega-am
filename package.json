{
  "name": "bodega-am",
  "version": "1.1.143",
  "description": "Sistema de Bodega A&M",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/josepatriciolee18-netizen/bodega-am.git"
  },
  "build": {
    "appId": "com.bodega-am.app",
    "productName": "Bodega A&M",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "styles.css",
      "app.js",
      "firebase-init.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "josepatriciolee18-netizen",
      "repo": "bodega-am",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "firebase": "^10.7.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
